---
import Layout from '@/layouts/BlogPost.astro'
import AboutHeroImage from '../assets/cg_rm18_0103.webp'
import Bio from '../components/Bio.astro'
---

<Layout
  title='About Me'
  description='About Me, Kino!'
  pubDate={new Date('March 05 2026')}
  heroImage={AboutHeroImage}
>
  <Bio />
</Layout>

<style>
  :global(.title *) {
    color: var(--primary);
  }

  :global(.title h1, .title h1:before, .title h1:after) {
    font-family: 'Impact Regular';
    text-transform: uppercase;
    letter-spacing: 0.4rem;
    white-space: nowrap;
    font-size: 8rem;
    font-weight: normal;

    display: flex;
    justify-content: center;
    align-items: center;
    user-select: none;
  }

  :global(.title h1:before, .title h1:after) {
    content: attr(data-text);
    position: absolute;
    color: transparent;
    -webkit-text-stroke: 0.08rem var(--primary);
  }

  :global(.title h1:before) {
    transform: translateY(16%) scale(0.9);
    transition: transform 1s ease-out;
    -webkit-clip-path: polygon(0 80%, 100% 80%, 100% 100%, 0 100%);
    clip-path: polygon(0 80%, 100% 80%, 100% 100%, 0 100%);
    z-index: -2;
  }

  :global(.title h1:after) {
    transform: translateY(10%) scale(0.95);
    transition: transform 0.6s ease-out;
    -webkit-clip-path: polygon(0 75%, 100% 75%, 100% 100%, 0 100%);
    clip-path: polygon(0 75%, 100% 75%, 100% 100%, 0 100%);
    z-index: -1;
  }
</style>
