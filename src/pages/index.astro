import WavyLines from '@/components/WavyLines.svelte'
import Welcome from '@/components/Welcome.svelte'
import Layout from '@/layouts/Layout.astro'

const title = "Kino Motion"
const description = 'Frontend Interaction Lab by Kino'
---

