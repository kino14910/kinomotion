---
import Layout from '@/layouts/Layout.astro'
import BlogLink from './BlogLink.svelte'

export interface Props {
  title: string
  description: string
  posts: Array<{
    id: string
    data: {
      title: string
      pubDate: Date
      heroImage?: ImageMetadata
    }
  }>
  basePath: string
  showImage?: boolean
  showDate?: boolean
}

const {
  title,
  description,
  posts,
  basePath,
  showImage = true,
  showDate = true,
} = Astro.props
---

<Layout title={title} description={description}>
  <main>
    <section>
      <ul>
        {
          posts.map(post => (
            <li>
              <BlogLink
                url={`/${basePath}/${post.id}/`}
                title={post.data.title}
                showDate={showDate}
                pubDate={post.data.pubDate}
              />
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</Layout>

<style>
  :global(.layout) {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
    height: min-content;
    position: relative;
  }
  main {
    flex: 1;
    margin: 0 auto;
    max-width: 1400px;
    padding: 1em 2em;
    box-sizing: border-box;
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  ul {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 1rem;
    list-style-type: none;
    margin: 0;
    padding: 0;
  }
  ul li {
    width: 100%;
  }
  ul li * {
    text-decoration: none;
    transition: 0.2s ease;
  }
  ul li img {
    margin-bottom: 0.5rem;
    border-radius: 12px;
  }
  @media (max-width: 720px) {
    ul {
      gap: 0.5em;
    }
    ul li {
      width: 100%;
      text-align: center;
    }
  }
</style>
